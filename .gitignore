# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
venv/
.venv/
env/
.env

# IDE / OS
.vscode/
.idea/
.DS_Store

# nnx training + example artifacts
runs/
tb_logs/
*.onnx
# Example-script output directories. Three examples write here:
#   examples/11_tinystories_lm.py        → artifacts/tinystories_lm/
#   examples/17_export_transformer_to_gguf.py → artifacts/lm_export/
#   examples/18_publish_to_ollama.py     → artifacts/ollama_bundle/
# Without ignoring the dir, a casual `git add -A` after running an
# example would sweep the .gguf binaries / tokenizer.json / Modelfile
# into the repo. Matches the runs/ pattern above.
artifacts/

# Coverage / docs build output
coverage.xml
# `site/` is mkdocs' default --site-dir; CI uses `--site-dir _site`
# (.github/workflows/{ci,release}.yml). Ignore both so neither
# materializes in `git status` after a local --strict build.
site/
_site/

# Local-only working specs / design docs (per repo convention,
# planning artifacts are not committed — only the implementation is).
# Without this, a stray local file under docs/specs/ or docs/superpowers/
# would show up untracked in `git status` and be vulnerable to an
# accidental `git add -A`. Belt-and-braces; mkdocs.yml already excludes
# both from the published site.
docs/specs/
docs/superpowers/

# Same family: CLAUDE.md is a working artifact for Claude Code sessions
# that doesn't belong in the public repo.
CLAUDE.md
